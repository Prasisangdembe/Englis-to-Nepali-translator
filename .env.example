APP_NAME=Limbu Translation System
VERSION=1.0.0
DEBUG=False
API_HOST=0.0.0.0
API_PORT=5000
API_KEY=change-me

DATABASE_URL=postgresql://limbu_user:limbu_password@db:5432/limbu_db
REDIS_URL=redis://redis:6379/0

MODEL_PATH=./models/saved
MLFLOW_URI=http://localhost:5001

LOG_LEVEL=INFO
LOG_FILE=limbu_translation.log

# Docker-specific database values (used by docker-compose.yml)
POSTGRES_DB=limbu_db
POSTGRES_USER=limbu_user
POSTGRES_PASSWORD=limbu_password
